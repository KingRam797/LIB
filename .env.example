# Local dev defaults use SQLite — no external DB required.
DB_CLIENT=sqlite            # sqlite | pg
SQLITE_PATH=./server/db/counting_house.db
DATABASE_URL=postgres://king:CHANGE_ME@localhost:5432/counting_house
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# REQUIRED IN PRODUCTION: bearer token guarding every /api route (except /api/health).
# Leave blank for open local dev. Generate one: openssl rand -hex 24
APP_TOKEN=
# Optional: free CoinGecko Demo key (100 calls/min, 10,000/mo). Leave blank to use keyless public API.
COINGECKO_DEMO_KEY=
# User anchors baked into seed; override if desired.
USER_BIRTH_YEAR=1997
RETIRE_AGE=55
NET_WORTH_TARGET_CENTS=100000000
