# Mmm! environment keys — copy to `.env.local` in this repo root and fill in.
# `.env.local` is gitignored; NEVER commit real values. For the live site, set
# these same names in Vercel → Project → Settings → Environment Variables.
# Loaded locally by mmm/integrations/env.ts (loadEnvLocal walks up to this root).

# --- Shopify Storefront API (Phase 1, required) -----------------------------
# Settings → Apps → Develop apps → Storefront API (read products + write cart).
# The Storefront token is PUBLIC-safe by design; the domain is the myshopify one.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Klaviyo (Phase 2 — quiz → profile sync) --------------------------------
# Private API key: Klaviyo → Settings → API keys. SERVER-SIDE ONLY.
KLAVIYO_PRIVATE_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- ReCharge (Phase 2/3 — subscription bundles) ----------------------------
# ReCharge → Apps & integrations → API tokens. SERVER-SIDE ONLY.
RECHARGE_API_TOKEN=sk_1x1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
