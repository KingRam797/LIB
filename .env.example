# Copy to .env for local development. NEVER commit real values — .env* is gitignored.

# --- Database ---
# Runtime role (RLS-constrained). Provisioned by `pnpm --filter @spendwhere/api db:migrate`.
DATABASE_URL=postgres://spendwhere_app:app-dev-password@localhost:5432/spendwhere
# Owner/admin connection used only by migrations.
ADMIN_DATABASE_URL=postgres://postgres:postgres@localhost:5432/spendwhere
# Password the migration runner assigns to the spendwhere_app role.
APP_DB_PASSWORD=app-dev-password

# --- Auth ---
# 32+ random bytes, e.g. `openssl rand -base64 48`
JWT_SECRET=change-me-to-a-long-random-string
# 32 bytes base64 for AES-256-GCM field encryption, e.g. `openssl rand -base64 32`
FIELD_ENCRYPTION_KEY=

# --- KYC (Persona) — leave empty for stub mode ---
PERSONA_API_KEY=
PERSONA_WEBHOOK_SECRET=
PERSONA_TEMPLATE_ID=
PERSONA_ENVIRONMENT=sandbox

# --- Vault (optional; env secrets are used when unset) ---
VAULT_ADDR=
VAULT_TOKEN=

# --- Document vault storage ---
# Local dir used when S3 is not configured (dev only)
VAULT_STORAGE_DIR=./vault-data
# Any S3-compatible store (DO Spaces / AWS S3 / MinIO). Setting S3_BUCKET switches the driver.
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
PORT=4000
