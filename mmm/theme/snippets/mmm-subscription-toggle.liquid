{% comment %}
  Mmm! — subscription/one-time purchase toggle. Build principle #2:
  SUBSCRIPTION-FIRST. Subscribe is default-checked and visually primary;
  one-time exists but is never the featured path.

  Works with the ReCharge-injected selling plans on the product. Expects:
    product      — the product object
    selected_selling_plan_id (optional) — preselect a specific plan

  Renders radio inputs named `purchase_option`; the PDP form JS maps the
  selection to `selling_plan` on the cart line item.
{% endcomment %}

{%- assign default_plan = nil -%}
{%- for group in product.selling_plan_groups -%}
  {%- for plan in group.selling_plans -%}
    {%- if default_plan == nil -%}
      {%- assign default_plan = plan -%}
    {%- endif -%}
    {%- if selected_selling_plan_id and plan.id == selected_selling_plan_id -%}
      {%- assign default_plan = plan -%}
    {%- endif -%}
  {%- endfor -%}
{%- endfor -%}

<fieldset class="mmm-purchase-toggle" data-mmm-purchase-toggle>
  <legend class="visually-hidden">How would you like it?</legend>

  {%- if default_plan -%}
    <label class="mmm-purchase-toggle__option mmm-purchase-toggle__option--featured">
      <input
        type="radio"
        name="purchase_option"
        value="subscribe"
        data-selling-plan-id="{{ default_plan.id }}"
        checked
      >
      <span class="mmm-purchase-toggle__label">
        <strong>Make it a ritual</strong>
        <span class="mmm-purchase-toggle__detail">
          Delivered every 30 days &middot; skip or cancel anytime, no hard feelings
        </span>
      </span>
      <span class="mmm-purchase-toggle__price">
        {{ default_plan.price_adjustments | map: 'price' | first | money | default: product.selected_or_first_available_variant.price | money }}
      </span>
    </label>
  {%- endif -%}

  <label class="mmm-purchase-toggle__option">
    <input type="radio" name="purchase_option" value="one_time" {% unless default_plan %}checked{% endunless %}>
    <span class="mmm-purchase-toggle__label">
      <span>Just this once</span>
    </span>
    <span class="mmm-purchase-toggle__price">
      {{ product.selected_or_first_available_variant.price | money }}
    </span>
  </label>
</fieldset>

{% stylesheet %}
.mmm-purchase-toggle {
  border: 0;
  padding: 0;
  margin: 0 0 var(--mmm-space-6);
  display: grid;
  gap: var(--mmm-space-2);
}
.mmm-purchase-toggle__option {
  display: flex;
  align-items: center;
  gap: var(--mmm-space-3);
  padding: var(--mmm-space-4);
  border: 1px solid var(--mmm-line);
  border-radius: var(--mmm-radius-md);
  background: var(--mmm-bg-raised);
  cursor: pointer;
}
.mmm-purchase-toggle__option--featured {
  border-color: var(--mmm-sunrise);
  box-shadow: var(--mmm-shadow-card);
}
.mmm-purchase-toggle__option:has(input:checked) {
  outline: 2px solid var(--mmm-sunrise);
  outline-offset: -1px;
}
.mmm-purchase-toggle__label { flex: 1; display: grid; gap: 2px; }
.mmm-purchase-toggle__detail { font-size: 0.875rem; color: var(--mmm-ink-soft); }
.mmm-purchase-toggle__price { font-weight: 700; }
{% endstylesheet %}
