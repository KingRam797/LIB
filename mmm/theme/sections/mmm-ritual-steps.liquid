{% comment %}
  Mmm! — ritual/steps block. Explains the three-step model (quiz → stack →
  ritual) or any stepwise story. Blocks are repeatable; defaults encode the
  habit-stacking language from the personalization research (cue → routine →
  reward; "pair it with your morning coffee").
{% endcomment %}

<section class="mmm-steps">
  <div class="mmm-steps__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="mmm-steps__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <ol class="mmm-steps__list">
      {%- for block in section.blocks -%}
        <li class="mmm-card mmm-steps__step" {{ block.shopify_attributes }}>
          <span class="mmm-steps__num">{{ forloop.index }}</span>
          <h3 class="mmm-steps__title">{{ block.settings.title }}</h3>
          <p class="mmm-steps__body">{{ block.settings.body }}</p>
        </li>
      {%- endfor -%}
    </ol>
  </div>
</section>

{% stylesheet %}
.mmm-steps { padding: var(--mmm-space-16) var(--mmm-space-6); }
.mmm-steps__inner { max-width: 64rem; margin: 0 auto; }
.mmm-steps__heading { text-align: center; margin: 0 0 var(--mmm-space-12); font-size: 2.25rem; }
.mmm-steps__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  gap: var(--mmm-space-6);
}
.mmm-steps__num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2.25rem;
  height: 2.25rem;
  border-radius: var(--mmm-radius-pill);
  background: var(--mmm-sunrise);
  color: var(--mmm-bg-raised);
  font-weight: 700;
}
.mmm-steps__title { font-size: 1.5rem; margin: var(--mmm-space-3) 0 var(--mmm-space-2); }
.mmm-steps__body { margin: 0; color: var(--mmm-ink-soft); }
{% endstylesheet %}

{% schema %}
{
  "name": "Mmm! Ritual Steps",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three steps. Then it's just mornings."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "textarea", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mmm! Ritual Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Tell us about you",
            "body": "Six questions, under two minutes. Your goals, your diet, your mornings."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Meet your stack",
            "body": "A right-dosed daily lineup, built from your answers. Here's exactly what's in it — and why."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Stack it with your coffee",
            "body": "Same time, same place, every day. We handle the remembering; skip anytime, no hard feelings."
          }
        }
      ]
    }
  ]
}
{% endschema %}
