{% comment %}
  Mmm! — homepage hero. Voice: respect / return / ritual. Warm, brief,
  no hype, no fear-selling. Default copy below passes the no-claims test;
  editable via the theme customizer, but any edit must stay
  structure/function-safe (§6).
{% endcomment %}

<section class="mmm-hero">
  <div class="mmm-hero__inner">
    <h1 class="mmm-hero__headline">{{ section.settings.headline }}</h1>
    <p class="mmm-hero__sub">{{ section.settings.subline }}</p>
    <div class="mmm-hero__actions">
      <a href="{{ section.settings.primary_link }}" class="mmm-btn mmm-btn--primary">
        {{ section.settings.primary_label }}
      </a>
      <a href="{{ section.settings.secondary_link }}" class="mmm-btn mmm-btn--quiet">
        {{ section.settings.secondary_label }}
      </a>
    </div>
  </div>
</section>

{% stylesheet %}
.mmm-hero {
  background: linear-gradient(160deg, var(--mmm-bg) 55%, #fbeadb 100%);
  padding: var(--mmm-space-24) var(--mmm-space-6) var(--mmm-space-16);
  text-align: center;
}
.mmm-hero__inner { max-width: 44rem; margin: 0 auto; }
.mmm-hero__headline { font-size: clamp(2.25rem, 6vw, 3.25rem); margin: 0 0 var(--mmm-space-4); }
.mmm-hero__sub {
  font-size: 1.125rem;
  color: var(--mmm-ink-soft);
  margin: 0 auto var(--mmm-space-8);
  max-width: 34rem;
}
.mmm-hero__actions { display: flex; gap: var(--mmm-space-3); justify-content: center; flex-wrap: wrap; }
{% endstylesheet %}

{% schema %}
{
  "name": "Mmm! Hero",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Your morning, made for you."
    },
    {
      "type": "textarea",
      "id": "subline",
      "label": "Subline",
      "default": "A two-minute quiz. A daily stack built around your goals. Delivered before you run out — that's the whole trick."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary CTA label",
      "default": "Build my ritual"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary CTA label",
      "default": "Meet the four"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary CTA link"
    }
  ],
  "presets": [{ "name": "Mmm! Hero" }]
}
{% endschema %}
